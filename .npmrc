# Конфиг по официальной вики Chevron «Getting Component Packages».
# Публичные пакеты (Angular, ng-bootstrap) — обычный npm.
registry=https://registry.npmjs.org/

# Скоуп @cvx (NextPage и пр.) — из Chevron Artifactory.
@cvx:registry=https://artifactory.chevron.com/api/npm/npm-local/
//artifactory.chevron.com/api/npm/npm-local/:always-auth=true
//artifactory.chevron.com/api/npm/npm-local/:_authToken=${CVX_ARTIFACTORY_TOKEN}

# Токен НЕ хранится здесь — берётся из переменной окружения CVX_ARTIFACTORY_TOKEN
